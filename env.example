# Required
GEMINI_API_KEY=your_key_here

# Gemini models — two tiers
GEMINI_TRIAGE_MODEL=gemini-2.0-flash
GEMINI_SMART_MODEL=gemini-2.5-pro-preview-05-06

# Optional — only needed if videos lack embedded subtitles
GROQ_API_KEY=your_key_here

# Processing config
GEMINI_DELAY_SECONDS=1
DELETE_VIDEOS_AFTER_TRANSCRIPT=true
MAX_CONCURRENT_DOWNLOADS=3
